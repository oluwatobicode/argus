# Database + Redis connection strings when using `infra/docker-compose.yml`.
# Copy the relevant lines into your local .env files:
#   app/backend/api/.env
#   app/backend/worker/.env

DATABASE_URL=postgresql://argus:argus@localhost:5432/argus
REDIS_URL=redis://localhost:6379

# API-only (also copy to app/backend/api/.env)
SESSION_SECRET=dev-secret-change-in-production
FRONTEND_URL=http://localhost:5173
DSN_HOST=localhost:3000
DSN_PROTOCOL=http
PORT=3000
