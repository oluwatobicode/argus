# Copy to infra/.env for docker-compose
#   cp infra/.env.example infra/.env

# --- Required (all deployments) ---
SESSION_SECRET=change-me-to-a-long-random-string

# --- Required if not using the postgres/redis services below (e.g. Railway-managed) ---
DATABASE_URL=postgresql://user:password@host:5432/argus?sslmode=require
REDIS_URL=redis://default:password@host:6379

# --- Optional (integrations) ---
RESEND_API_KEY=
FROM_EMAIL=Argus <noreply@argus.dev>

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Billing (Bachs) ---
BACHS_API_KEY=
BACHS_PRO_PRODUCT_ID=
BACHS_WEBHOOK_SECRET=
BACHS_SERVER=sandbox

# Dogfooding — dashboard reports its own crashes (optional)
VITE_ARGUS_DSN=
