{
  "name": "@argusdev/sdk-core",
  "version": "0.2.0",
  "description": "Shared internals for Argus SDKs — DSN parsing, envelope building, transport. Not installed directly.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "~6.0.3"
  },
  "license": "MIT",
  "author": "Treasure Odetokun",
  "homepage": "https://github.com/oluwatobicode/argus#readme",
  "keywords": [
    "argus",
    "error-tracking",
    "monitoring",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oluwatobicode/argus.git",
    "directory": "packages/sdk-core"
  },
  "publishConfig": {
    "access": "public"
  }
}
