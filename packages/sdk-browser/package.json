{
  "name": "@argus/sdk-browser",
  "version": "0.1.0",
  "description": "Argus SDK for browsers — window.onerror, unhandled rejections, breadcrumbs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@argus/sdk-core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "~6.0.3"
  }
}
